# =============================================================================
# 易拍选（EpicShot）生产环境配置模板 V1.2.0
# 复制此文件为 .env 并填写实际值
# =============================================================================

# --- 必填 ---
NODE_ENV=production
JWT_SECRET=your-256-bit-secret-here-change-me

# --- 数据库 ---
# DB_PATH=./data/epicshot.db  (默认)

# --- 服务器 ---
PORT=3000
# CORS_ORIGIN=https://your-domain.com

# --- AI 服务 ---
# AI_SERVICE_URL=https://ai-service.your-domain.com
# AI_RETRY_MAX=1
# AI_RETRY_DELAY=2000

# --- 邮件通知 (可选) ---
# EMAIL_ENABLED=true
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=noreply@epicshot.com
# EMAIL_PASS=your-smtp-password
# EMAIL_FROM=noreply@epicshot.com

# --- CDN ---
# CDN_SECRET=your-cdn-signing-secret

# --- APM 监控 ---
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id