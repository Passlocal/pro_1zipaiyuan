# =============================================================================
# 易拍选 (EpicShot) V1.19 生产环境配置模板
# 使用方式: cp .env.production .env && 按实际情况修改
# =============================================================================

# --- 基础配置 ---
NODE_ENV=production
PORT=3000
JWT_SECRET=           # 【必填】生产环境 JWT 密钥，使用 openssl rand -hex 64 生成
JWT_EXPIRES_IN=7d
LOG_LEVEL=INFO

# --- CORS 跨域 ---
# 生产环境必须替换为实际前端域名，多个用逗号分隔
CORS_ORIGINS=https://epicshot.com,https://www.epicshot.com,https://admin.epicshot.com

# =============================================================================
# 1. 微信 OAuth 登录（已有框架，需对接真实凭证）
# =============================================================================
# 申请地址: https://open.weixin.qq.com/
# 当前状态: demo 模式（WECHAT_APP_ID 为空时自动走模拟扫码）
WECHAT_APP_ID=         # 【必填】微信开放平台 AppID
WECHAT_APP_SECRET=     # 【必填】微信开放平台 AppSecret
WECHAT_REDIRECT_URI=https://api.epicshot.com/v1/auth/wechat/callback
# 对接步骤:
# 1. 在 open.weixin.qq.com 注册开发者账号，创建网站应用
# 2. 填写回调域名为你的域名
# 3. 获取 AppID 和 AppSecret 填入上方
# 4. 代码改动: server.js 中 isRealWechat() 返回 true 后，/v1/auth/wechat/qrcode 会自动调用微信 API 生成真实二维码
# 5. 微信回调 /v1/auth/wechat/callback 会接收 code 换取 access_token 和用户信息
# 6. 无需修改任何业务代码，仅需配置凭证即可切换

# =============================================================================
# 2. AI 服务（已有框架，需对接真实 AI 服务）
# =============================================================================
# 推荐方案: 阿里云百炼 / 腾讯混元 / OpenAI API
# 当前状态: 内置 Mock（AI_SERVICE_URL 为空时返回模拟预览）
AI_SERVICE_URL=        # 【推荐】AI 服务 API 地址，如 https://dashscope.aliyuncs.com/api/v1/services/aigc/image-generation/generation
AI_SERVICE_KEY=        # 【推荐】AI 服务 API Key
AI_RETRY_MAX=3         # AI 调用失败重试次数
AI_RETRY_DELAY=2000    # 重试间隔(ms)
# 对接步骤:
# 1. 选择 AI 服务商（推荐阿里云百炼，支持风格迁移模型）
# 2. 在 server.js 的 AI 调用处（约 L1946-1972 和 L2009-2037）添加真实 HTTP 调用
# 3. /v1/ai/style-preview 目前返回模拟滤镜预览，改为调用 AI 图像生成 API
# 4. /v1/ai/style-samples 异步任务框架已就绪，只需替换 callAI() 中的 fetch 逻辑
# 5. /v1/ai/color-check 和 /v1/ai/consistency-check 同样需要对接 AI 分析服务

# =============================================================================
# 3. 邮件服务（已有框架，需对接真实 SMTP）
# =============================================================================
# 推荐方案: 阿里云邮件推送 / SendGrid / 腾讯企业邮
# 当前状态: 配置为空时静默跳过邮件发送
EMAIL_ENABLED=true
EMAIL_HOST=smtp.example.com      # 【必填】SMTP 服务器地址
EMAIL_PORT=587                   # 587(TLS) 或 465(SSL)
EMAIL_USER=                      # 【必填】SMTP 账号
EMAIL_PASS=                      # 【必填】SMTP 密码
EMAIL_FROM=noreply@epicshot.com  # 发件人地址
# 对接步骤:
# 1. 注册邮件服务商，获取 SMTP 凭证
# 2. 填入上方配置即可，代码无需修改（nodemailer 已集成）
# 3. 邮件发送场景: 任务指派通知、争议预警、客户申请修改、催稿提醒

# =============================================================================
# 4. CDN / 对象存储（已有框架，需对接云存储）
# =============================================================================
# 推荐方案: 阿里云 OSS + CDN / 腾讯云 COS + CDN / AWS S3 + CloudFront
# 当前状态: 本地文件系统存储（uploads/ 目录）
CDN_SECRET=                      # 【推荐】CDN 签名密钥，用于生成防盗链 URL
CDN_BASE_URL=                    # 【推荐】CDN 域名，如 https://cdn.epicshot.com
# 对接步骤:
# 1. 开通对象存储服务（OSS/COS/S3），创建 Bucket
# 2. 安装对应 SDK: npm install ali-oss 或 npm install cos-nodejs-sdk-v5
# 3. 修改 server.js 中的文件上传逻辑（multer 存储引擎改为云上传）
# 4. 修改 server.js 中所有返回图片 URL 的地方，替换为 CDN 域名
# 5. /v1/images/:id/signed-url 已实现签名 URL 生成，对接 CDN 私密 Bucket
# 6. 影响范围: 图片上传、缩略图、交付包下载、作品集导出

# =============================================================================
# 5. HTTPS / SSL 证书（已有框架，需提供证书文件）
# =============================================================================
# 推荐方案: Let's Encrypt (免费) / 阿里云 SSL / 腾讯云 SSL
# 当前状态: 证书不存在时自动降级为 HTTP
HTTPS_ENABLED=true
HTTPS_KEY_PATH=./certs/key.pem       # SSL 私钥路径
HTTPS_CERT_PATH=./certs/cert.pem     # SSL 证书路径
HTTPS_PORT=3443
# 对接步骤:
# 1. 申请 SSL 证书并下载
# 2. 将 key.pem 和 cert.pem 放入 certs/ 目录
# 3. 或在生产环境用 Nginx 反向代理处理 HTTPS，后端只跑 HTTP

# =============================================================================
# 6. 数据库升级（SQLite → PostgreSQL/MySQL）
# =============================================================================
# 推荐方案: PostgreSQL 14+ (推荐) / MySQL 8.0+
# 当前状态: SQLite (better-sqlite3)，文件存储在 data/epicshot.db
# 对接步骤:
# 1. 安装驱动: npm install pg (PostgreSQL) 或 npm install mysql2 (MySQL)
# 2. 创建数据库迁移脚本，将 SQLite 建表语句转为目标数据库方言
# 3. 将 server.js 中所有 db.prepare().run()/.get()/.all() 替换为参数化 SQL
# 4. SQLite 特殊语法需替换: datetime('now') → NOW(), IS NULL → IS NULL(通用)
# 5. 建议引入 ORM 层（如 Drizzle ORM / Prisma）降低迁移成本
# 6. 影响范围: 整个 server.js（约 400+ 处数据库调用）

# =============================================================================
# 7. Sentry 错误监控（已有框架，需填入 DSN）
# =============================================================================
# 申请地址: https://sentry.io/
SENTRY_DSN=            # 【推荐】Sentry DSN，用于生产环境错误追踪
# 对接步骤: 在 Sentry 创建项目 → 复制 DSN → 填入上方即可，代码已集成

# =============================================================================
# 8. 云盘导入（Mock 数据，需对接真实 API）
# =============================================================================
# 推荐方案: 百度网盘开放平台 / 阿里云盘 API
# 当前状态: /v1/import/cloud-drive 返回硬编码的 Mock 数据
# 对接步骤:
# 1. 注册对应云盘开放平台，获取 API Key
# 2. 实现 OAuth 授权流程，获取用户 access_token
# 3. 替换 server.js L2269-2284 的 Mock 数据为真实 API 调用
# 4. 支持的文件列表操作: 浏览目录、获取文件信息、下载文件

# =============================================================================
# 9. 微信截图 OCR 解析（Mock 数据，需对接 OCR 服务）
# =============================================================================
# 推荐方案: 腾讯云 OCR / 百度 OCR / 阿里云 OCR
# 当前状态: OCR_SERVICE_URL 为空时返回空结果 + 提示
OCR_SERVICE_URL=       # 【可选】OCR 服务地址，如 https://ocr.tencentcloudapi.com
OCR_SERVICE_KEY=       # 【可选】OCR 服务 API Key

# =============================================================================
# 10. WebSocket（前端硬编码域名）
# =============================================================================
# 前端文件: /workspace/epicshot-frontend/src/composables/useWebSocket.ts:4
# 当前硬编码: wss://api.epicshot.com/v1/ws
# 对接步骤: 替换为实际 WebSocket 地址，或改为从环境变量读取 VITE_WS_URL

# =============================================================================
# 11. Rate Limiter 调整（已环境变量化，开发/生产自动区分）
# =============================================================================
# 代码已自动根据 NODE_ENV 切换:
#   开发环境: 通用5000次, 登录30次, 上传100次/15min
#   生产环境: 通用1000次, 登录10次, 上传20次/15min
# 如需自定义:
# RATE_WINDOW_MS=900000      # 限流窗口(ms)，默认15分钟
# GENERAL_RATE_MAX=1000      # 通用接口限流
# AUTH_RATE_MAX=10           # 登录接口限流
# UPLOAD_RATE_MAX=20         # 上传接口限流

# =============================================================================
# 12. 前端构建配置
# =============================================================================
# 前端文件: /workspace/epicshot-frontend/.env.production
# 当前默认: VITE_API_URL 为空（同源部署），VITE_WS_URL 为空（自动生成）
# 生产环境: 如前后端分离部署，需设置 VITE_API_URL=https://api.epicshot.com/v1
# 构建命令: VITE_API_URL=https://api.epicshot.com/v1 npm run build